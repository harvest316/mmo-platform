# auditandfix.com — Environment Variables
#
# Set these in your hosting control panel (cPanel > Software > PHP Environment Variables,
# or Plesk > PHP Settings, or vhost config), NOT in .htaccess for production.
#
# For Apache shared hosting with no server config access, uncomment the SetEnv lines
# in .htaccess and fill in the real values there — but ensure .htaccess is not web-readable
# (the existing <FilesMatch> block already blocks .env; .htaccess itself is always protected
# by Apache). SetEnv in .htaccess is readable by other PHP users on shared hosting, so
# prefer server-level env vars where possible.

# Cloudflare Worker
AUDITANDFIX_WORKER_URL=https://auditandfix-api.auditandfix.workers.dev
AUDITANDFIX_WORKER_SANDBOX_URL=https://auditandfix-api-test.auditandfix.workers.dev
AUDITANDFIX_WORKER_SECRET=CHANGE_ME

# Business / Legal
LEGALS_EMAIL=
BUSINESS_ADDRESS=
OPERATOR_NAME=
BUSINESS_PHONE=
BUSINESS_ABN=

# PayPal
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=CHANGE_ME
PAYPAL_CLIENT_SECRET=CHANGE_ME
