{
  "name": "mmo-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Shared services platform for outreach business projects (333Method, 2Step, etc.)",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "pg": "^8.20.0"
  },
  "scripts": {
    "init-db": "node scripts/init-messages-db.js",
    "pipeline": "node src/pipeline-runner.js",
    "pipeline:once": "node src/pipeline-runner.js --once",
    "monitor": "sh scripts/monitoring-checks.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e:web": "npx playwright test tests/e2e/website.spec.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.1.2",
    "vitest": "^4.1.1"
  }
}
