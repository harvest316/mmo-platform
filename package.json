{
  "name": "mmo-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Shared services platform for outreach business projects (333Method, 2Step, etc.)",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-iam": "^3.1024.0",
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/client-ses": "^3.1024.0",
    "@aws-sdk/client-sesv2": "^3.1024.0",
    "@aws-sdk/client-sns": "^3.1024.0",
    "@aws-sdk/client-sts": "^3.1024.0",
    "better-sqlite3": "^9.4.3",
    "pg": "^8.20.0"
  },
  "scripts": {
    "init-db": "node scripts/init-messages-db.js",
    "pipeline": "node src/pipeline-runner.js",
    "pipeline:once": "node src/pipeline-runner.js --once",
    "monitor": "sh scripts/monitoring-checks.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.1",
    "vitest": "^4.1.1"
  }
}
